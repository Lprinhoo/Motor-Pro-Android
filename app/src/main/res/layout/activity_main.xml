<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0B0B"
    tools:context=".MainActivity">

    <!-- Fundo do Mapa (Midnight) -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Botão de Perfil (Quadrado com cantos levemente arredondados no Topo Esquerdo) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardProfile"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_margin="20dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="#16BC4E"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:strokeColor="#F5F6FC"
        app:strokeWidth="2dp"
        app:layout_anchorGravity="top|start">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_myplaces"
            android:padding="14dp"
            app:tint="#F5F6FC" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Container Inferior (Midnight Style) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#0B0B0B"
        app:cardCornerRadius="28dp"
        app:cardElevation="12dp"
        app:strokeColor="#333333"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXPLORAR"
                android:textColor="#F5F6FC"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"
                android:alpha="0.7"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnServices"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#16BC4E"
                android:text="VISUALIZAR SERVIÇOS"
                android:textAllCaps="false"
                android:textColor="#F5F6FC"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:cornerRadius="20dp"
                app:icon="@android:drawable/ic_menu_agenda"
                app:iconTint="#F5F6FC"
                app:iconPadding="12dp"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAction"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:backgroundTint="#16BC4E"
                    android:text="PROCURAR OFICINA"
                    android:textAllCaps="false"
                    android:textColor="#F5F6FC"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="20dp"
                    app:icon="@android:drawable/ic_menu_search"
                    app:iconTint="#F5F6FC"
                    app:iconPadding="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancel"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:backgroundTint="#0B0B0B"
                    android:text="CANCELAR BUSCA"
                    android:textAllCaps="false"
                    android:textColor="#EA4335"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:cornerRadius="20dp"
                    app:strokeColor="#EA4335"
                    app:strokeWidth="1dp"
                    app:icon="@android:drawable/ic_menu_close_clear_cancel"
                    app:iconTint="#EA4335"
                    app:iconPadding="12dp"/>
            </FrameLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>